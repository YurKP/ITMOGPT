# === LLM Provider ===
# "openai" or "yandex"
LLM_PROVIDER=openai

# === OpenAI / OpenAI-compatible ===
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# === Yandex Cloud (if LLM_PROVIDER=yandex) ===
YA_API_KEY=
YA_FOLDER_ID=
YA_GPT_MODEL=yandexgpt/latest
YA_EMBED_MODEL=text-search-doc/latest

# === Telegram Bot ===
BOT_TOKEN=
# Comma-separated usernames (empty = allow all)
ALLOWED_USERS=

# === Data ===
DATA_DIR=./data
CHROMA_DIR=./chroma_db

# === Gostomysl ===
ARXIV_MAX_RESULTS=100
GOSTOMYSL_TOP_K_BM25=50
GOSTOMYSL_TOP_K_EMBED=25
GOSTOMYSL_TOP_K_FINAL=10

# === Вобщаге integration ===
# URL of vopstchage backend (e.g. https://xn--80abcgk4c7d.fun or http://vobshage-backend:8000)
VOBSHAGE_API_URL=

# === Web ===
WEB_HOST=0.0.0.0
WEB_PORT=8080

# === Caddy (docker-compose) ===
DOMAIN=localhost
